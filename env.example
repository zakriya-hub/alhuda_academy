# ─────────────────────────────────────────────────────
#  Al-Huda Quran Academy — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill every value below
#  3. NEVER commit .env to git
# ─────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── MySQL ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=alhuda_academy

# ── Gmail (Nodemailer) ────────────────────────────────
# Use an App Password, NOT your real Gmail password
# How to get one → https://myaccount.google.com/apppasswords
GMAIL_USER=mzakriya837@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Admin email that receives every new booking alert
ADMIN_EMAIL=mzakriya837@gmail.com

# ── WhatsApp (CallMeBot — 100% FREE) ─────────────────
# Setup takes 2 minutes:
#  1. Add +34 644 59 78 84 to your WhatsApp contacts
#  2. Send:  I allow callmebot to send me messages
#  3. You'll receive your apikey via WhatsApp
#  Docs → https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=+923266187409
WHATSAPP_APIKEY=your_callmebot_apikey_here

# ── CORS ──────────────────────────────────────────────
# Your frontend URL (no trailing slash)
# Local dev:   http://localhost:5500
# Production:  https://yourdomain.com
FRONTEND_URL=http://localhost:5500
